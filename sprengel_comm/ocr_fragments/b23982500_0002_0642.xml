<head>Cap. CLII. <foreign xml:lang="grc">Σίκυς ἄγριος</foreign> (<foreign xml:lang="grc">σίκυος ἀγρίου</foreign> Theophr.<ref target="#fn11">¹¹</ref>,<lb/>
