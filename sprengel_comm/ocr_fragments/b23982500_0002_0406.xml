scribit, nisi quod fructum dicat <foreign xml:lang="grc">ἀραιόν</foreign> loco <foreign xml:lang="grc">ἁδροῦ</foreign>.<ref target="#fn95">⁹⁵</ref> Nisi,<lb/>
